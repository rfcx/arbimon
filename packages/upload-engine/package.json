    "lint-fix": "eslint . --fix && prettier . --loglevel warn --write",
    "lint:eslint": "eslint . --cache",
    "lint:prettier": "prettier . --check",
    "test": "concurrently -r -m 1 --kill-others-on-fail \"pnpm:test:* -- --run\"",
    "test:unit": "vitest .unit.test."
